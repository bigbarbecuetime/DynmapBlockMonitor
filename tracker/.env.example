# Copy this file to ".env" and fill in your server's details, then `docker compose up -d`.

# --- Dynmap (chunk / map-tile changes) ---
DYNMAP_URL=http://your-server:8123
WORLD_NAME=world
MAP_TYPE=flat2

# --- Minecraft server (player count via Server List Ping) ---
# The host and port you connect to in-game. If the server hides a non-standard port
# behind an SRV record, look it up: nslookup -type=SRV _minecraft._tcp.<host>
MC_HOST=your-server
MC_PORT=25565

# --- Tracker behavior (optional; these are the defaults) ---
POLL_INTERVAL=10
SAVE_IMAGES=false
# HTTP_TIMEOUT=8
